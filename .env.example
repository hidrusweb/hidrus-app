# --- Uso no dia a dia (copie para .env; não commitar) ---
# API remota de desenvolvimento:
EXPO_PUBLIC_API_URL=https://apidev.hidrusweb.com/api
# remote | local_ios | local_android
EXPO_PUBLIC_API_MODE=remote
EXPO_PUBLIC_APP_BEARER_TOKEN=

# API local (Laravel): php artisan serve --host=0.0.0.0 --port=8000
# Emulador Android: EXPO_PUBLIC_API_MODE=local_android (usa 10.0.2.2:8000)
# Simulador iOS: EXPO_PUBLIC_API_MODE=local_ios
# iPhone físico / dispositivo na mesma rede: EXPO_PUBLIC_API_URL=http://IP_DO_PC:8000/api e EXPO_PUBLIC_API_MODE=remote

# --- Builds EAS (Play Store / TestFlight) ---
# O .env não vai para o servidor do EAS. URLs por perfil estão em eas.json:
#   production → https://api.hidrusweb.com/api
#   preview / development → https://apidev.hidrusweb.com/api
# Comando loja: eas build --platform android --profile production
