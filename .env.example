EXPO_PUBLIC_API_URL=https://apidev.hidrusweb.com/api
# remote | local_ios | local_android
EXPO_PUBLIC_API_MODE=remote
EXPO_PUBLIC_APP_BEARER_TOKEN=

# API local (Laravel): php artisan serve --host=0.0.0.0 --port=8000
# iPhone físico: defina EXPO_PUBLIC_API_URL=http://SEU_IP_LAN:8000/api (ip do Mac na Wi‑Fi)
# e EXPO_PUBLIC_API_MODE=remote para usar essa URL.
